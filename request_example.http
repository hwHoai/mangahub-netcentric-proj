@baseUrl = http://localhost:8081
@mangaId = MANGA_ID_HERE
@chapterId = CHAPTER_ID_HERE
@token = ACCESS_TOKEN_HERE
@username = testuser
@password = password123

### Health check
GET {{baseUrl}}/api/v1/health

### Signup by username
POST {{baseUrl}}/api/v1/signup
Content-Type: application/json

{
    "username": "{{username}}",
    "password": "{{password}}"
}

### Login by username
POST {{baseUrl}}/api/v1/login
Content-Type: application/json

{
    "username": "{{username}}",
    "password": "{{password}}"
}

### Refresh token
POST {{baseUrl}}/api/v1/auth/refresh
Content-Type: application/json

{
    "refresh_token": "REFRESH_TOKEN_HERE"
}

### List mangas (with pagination)
GET {{baseUrl}}/api/v1/mangas?limit=10&offset=0

### Get manga detail
GET {{baseUrl}}/api/v1/mangas/{{mangaId}}

### Get manga chapters
GET {{baseUrl}}/api/v1/mangas/{{mangaId}}/chapters

### Read chapter (Public)
GET {{baseUrl}}/api/v1/chapters/{{chapterId}}

### Get chat history
GET {{baseUrl}}/api/v1/mangas/{{mangaId}}/messages

### Get chat history
GET {{baseUrl}}/api/v1/quotes

###########################################################
# User Manga APIs (Require Authentication)
###########################################################

### Follow a manga
POST {{baseUrl}}/api/v1/user/mangas/{{mangaId}}/follow
Authorization: Bearer {{token}}

### Unfollow a manga
DELETE {{baseUrl}}/api/v1/user/mangas/{{mangaId}}/follow
Authorization: Bearer {{token}}

### Get followed mangas
GET {{baseUrl}}/api/v1/user/mangas/following?limit=10&offset=0
Authorization: Bearer {{token}}

### Sync/Create new chapter from MangaDex (Trigger UDP Notification)
# This will notify all users who follow this manga via UDP
POST {{baseUrl}}/api/v1/mangas/{{mangaId}}/chapters
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "mangadex_chapter_id": "MANGADEX_CHAPTER_ID_HERE"
}

### Read chapter (Authenticated - Triggers TCP Sync)
GET {{baseUrl}}/api/v1/user/chapters/{{chapterId}}
Authorization: Bearer {{token}}

### Get current user profile
GET {{baseUrl}}/api/v1/auth/me
Authorization: Bearer {{token}}

### Get reading history
GET {{baseUrl}}/api/v1/user/history?limit=10&offset=0
Authorization: Bearer {{token}}